# =========================================================
# SHARED ENVIRONMENT CONFIG
# Used by: air_quality_ingest.py, seismic_mqtt.py, api_server.py
# Place this file in the same folder as all three scripts.
# =========================================================

# ---- Database connection ----
SYSTEM_DB_HOST=127.0.0.1
SYSTEM_DB_PORT=5432
SYSTEM_DB_USER=aq_user
SYSTEM_DB_PASSWORD=UisI_2026##
# Kept modest by default since all three services may run on the same
# low-memory Raspberry Pi. Raise these only if you're on a bigger box and
# see pool-exhaustion warnings under load.
SYSTEM_DB_POOL_MIN=2
SYSTEM_DB_POOL_MAX=10
# When true, every service mirrors its logs into the `service_logs` table
# in the air_quality database (tagged by a `service` column), queryable via
# SQL or GET /api/system/logs. Console output (captured by systemd's
# journal) is unaffected either way.
DB_LOG_ENABLED=true
DB_LOG_TABLE=service_logs

# --- Database names ----
AQ_DB_NAME=IOT_aq_sensor_data
SEISMIC_DB_NAME=IOT_seismic_sensor_data
SMS_DB_NAME=IOT_sms_telemetry
API_DB_NAME=IOT_api
LOG_DB_NAME=IOT_service_logs

# ---- Air Quality Ingestion (TCP / HJ212) ----
AQ_SERVER_HOST=0.0.0.0
AQ_SERVER_PORT=1935
AQ_LEAD_POLL_INTERVAL=30
# How often (seconds) the in-memory station list is reloaded from the
# database `stations` table, so stations added/edited via import_stations.py
# or direct SQL are picked up without restarting the service.
AQ_STATIONS_REFRESH_INTERVAL_SEC=300

# ---- MQTT (Seismic) ----
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TIMEOUT_SEC=60
MQTT_TOPIC=seismic/stations/+/telemetry
MQTT_USER=mqtt_user_seismic
MQTT_PASSWORD=UisI_2026##

# ---- SMS (Seismic, second channel via SIM800L) ----
# See sim800l.py's module docstring for wiring notes. SIM800_SERIAL_PORT is
# the only wiring-dependent setting here — point it at whatever serial
# device Linux exposes for your UART/adapter.
SMS_INGESTION_ENABLED=true
SIM800_SERIAL_PORT=/dev/serial0
SIM800_BAUDRATE=9600
SMS_POLL_INTERVAL_SEC=30
# Comma-separated allowlist of sender numbers, e.g. +639171234567,+639181234567
# Leave blank to accept SMS telemetry from any sender.
SMS_ALLOWED_SENDERS=

# ---- API Server ----
API_PORT=8000
# Format: token:owner_label,token:owner_label,...
API_KEYS=YourSecureToken123:Internal Web Dashboard,MobileAppKey_xyz789:Android/iOS Mobile App,PartnerSync_abc456:Third-Party Data Sync Client
