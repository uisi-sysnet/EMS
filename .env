# =========================================================
# SHARED ENVIRONMENT CONFIG
# Used by: air_quality_ingest.py, seismic_mqtt.py, api_server.py
# Place this file in the same folder as all three scripts.
# =========================================================

# ---- Air Quality Database ----
AQ_DB_HOST=127.0.0.1
AQ_DB_PORT=5432
AQ_DB_NAME=air_quality
AQ_DB_USER=aq_user
AQ_DB_PASSWORD=UisI_2026##

# ---- Seismic Database ----
SEISMIC_DB_HOST=localhost
SEISMIC_DB_PORT=5432
SEISMIC_DB_NAME=seismic_sensor_data
SEISMIC_DB_USER=seismic_user
SEISMIC_DB_PASSWORD=UisI_2026##

# ---- Air Quality Ingestion (TCP / HJ212) ----
AQ_SERVER_HOST=0.0.0.0
AQ_SERVER_PORT=1935
AQ_LEAD_POLL_INTERVAL=30

# ---- MQTT (Seismic) ----
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TIMEOUT_SEC=60
MQTT_TOPIC=seismic/stations/+/telemetry
MQTT_USER=mqtt_user_seismic
MQTT_PASSWORD=UisI_2026##

# ---- API Server ----
API_PORT=8000
# Format: token:owner_label,token:owner_label,...
API_KEYS=YourSecureToken123:Internal Web Dashboard,MobileAppKey_xyz789:Android/iOS Mobile App,PartnerSync_abc456:Third-Party Data Sync Client